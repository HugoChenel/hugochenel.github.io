---
interface Post {
  category: string;
  title: string;
  date: string;
  href: string;
  excerpt?: string;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<ul class="post-list">
  {
    posts.map((post) => (
      <li class="post-item">
        <a href={post.href} class="post-link">
          <div class="post-meta">
            <span class="post-category">{post.category}</span>
            <span class="post-date">{post.date}</span>
          </div>
          <h3 class="post-title">{post.title}</h3>
          {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  .post-item {
    border-top: 1px solid var(--border);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: block;
    padding: 2rem 0;
    transition: opacity 0.2s;
  }

  .post-link:hover {
    opacity: 0.6;
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 0.6rem;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-date {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.35;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .post-excerpt {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 640px;
    margin-top: 0.4rem;
  }
</style>

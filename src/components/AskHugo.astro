---
import type { MemoryEntry } from '../utils/buildMemoryIndex';

interface Props {
  index: MemoryEntry[];
}
const { index } = Astro.props;

const SUGGESTED = [
  "How do machine learning models help study cancer?",
  "How do you train for Hyrox?",
  "How does hyperbaric oxygen therapy work?",
  "What is single-cell RNA-seq used for?",
  "How do you improve VO2max?",
  "What supplements support athletic recovery?",
  "How does sensory deprivation affect the brain?",
  "What is zone-2 cardio and why does it matter?",
];
---

<div class="ah-shell">
  <div class="ah-dev-banner" role="status">
    <div class="ah-dev-banner-inner">
      <div class="ah-dev-icon" aria-hidden="true">⚠</div>
      <h2 class="ah-dev-title">Under Development</h2>
      <p class="ah-dev-body">
        This page is a work in progress. The search engine and answer quality
        are still being improved — responses may be incomplete, inaccurate,
        or miss relevant content.
      </p>
    </div>
  </div>
  <div class="ah-thread" id="ah-thread">
    <div class="ah-welcome" id="ah-welcome">
      <p class="ah-welcome-eye">Science · Training · Biohacking</p>
      <h1 class="ah-welcome-title">What would you like to explore?</h1>
      <p class="ah-welcome-sub">Ask about research, protocols, or performance.<br/>Answers come only from this site's content.</p>
      <div class="ah-chips" id="ah-chips">
        {SUGGESTED.map((s) => (
          <button type="button" class="ah-chip" data-query={s}>{s}</button>
        ))}
      </div>
    </div>
    <div id="ah-msgs"></div>
  </div>

  <div class="ah-composer">
    <div class="ah-composer-wrap">
      <form id="ah-form" autocomplete="off">
        <div class="ah-composer-box">
          <textarea
            id="ah-input"
            class="ah-input"
            placeholder="Ask a question…"
            rows="1"
            spellcheck="false"
            aria-label="Ask a question"
          ></textarea>
          <button type="submit" class="ah-send" id="ah-send" aria-label="Send">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
              stroke-linejoin="round" width="16" height="16">
              <line x1="12" y1="19" x2="12" y2="5"/>
              <polyline points="5 12 12 5 19 12"/>
            </svg>
          </button>
        </div>
      </form>
      <div class="ah-footer-row">
        <span class="ah-note">Searches Hugo's public website content only — no AI API</span>
        <button type="button" class="ah-clear" id="ah-clear" hidden>New conversation</button>
      </div>
    </div>
  </div>
</div>

<!-- Bridge: pass build-time index to the module script via window global.
     define:vars forces is:inline, which runs as a classic script (synchronous),
     guaranteed before the deferred module script below reads window.__ahIndex. -->
<script define:vars={{ __ahIndex: index }}>
  window.__ahIndex = __ahIndex;
</script>

<script>
// ═════════════════════════════════════════════════════════════════════════════
// IMPORTS
// ═════════════════════════════════════════════════════════════════════════════
import MiniSearch from 'minisearch';

// ═════════════════════════════════════════════════════════════════════════════
// TYPES
// ═════════════════════════════════════════════════════════════════════════════
interface Entry {
  id: string;
  title: string;
  url: string;
  category: string;
  excerpt: string;
  tags: string[];
  headings: string[];
  body: string;
  _score?: number;
}
interface Turn { role: 'user' | 'assistant'; text: string; sources: Entry[]; }
type QueryType =
  | 'new_topic'
  | 'identity_about'
  | 'explain_followup'
  | 'direct_followup'
  | 'ambiguous_followup';

// ═════════════════════════════════════════════════════════════════════════════
// CONFIG
// Set DEBUG = true locally to see retrieval trace in the browser console.
// ═════════════════════════════════════════════════════════════════════════════
const DEBUG = false;
const MIN_MS_SCORE = 2.5; // minimum MiniSearch BM25 score for a confident result

function dbg(...args: unknown[]): void {
  if (DEBUG) console.log('[AskHugo]', ...args);
}

// ═════════════════════════════════════════════════════════════════════════════
// INDEX — injected at build time, bridged to this module via window global
// ═════════════════════════════════════════════════════════════════════════════
const INDEX: Entry[] = (window as unknown as Record<string, unknown>).__ahIndex as Entry[] ?? [];

// ═════════════════════════════════════════════════════════════════════════════
// MINISEARCH INSTANCE
// Fields indexed (with boosts): title > headings/tags > category > excerpt > body
// Stored fields are returned unchanged with every search result.
// ═════════════════════════════════════════════════════════════════════════════
const ms = new MiniSearch({
  idField: 'id',
  fields: ['title', 'headingsText', 'tagsText', 'category', 'excerpt', 'body'],
  storeFields: ['id', 'title', 'url', 'category', 'excerpt', 'tags', 'headings', 'body'],
});

ms.addAll(
  INDEX.map(e => ({
    ...e,
    headingsText: (e.headings ?? []).join(' '),
    tagsText: (e.tags ?? []).join(' '),
  }))
);

dbg(`MiniSearch ready — ${INDEX.length} entries indexed`);

// ═════════════════════════════════════════════════════════════════════════════
// SYNONYM MAP
// Used for two purposes:
//   1. Hard topic filter: entry must contain a key term or one of its synonyms
//   2. Query expansion for short/ambiguous queries
// ═════════════════════════════════════════════════════════════════════════════
const SYNONYMS = new Map<string, string[]>([
  ['aging',        ['aging', 'ageing', 'longevity', 'biological', 'epigenetic', 'antiaging', 'lifespan']],
  ['cancer',       ['cancer', 'oncology', 'tumor', 'tumour', 'transcriptomics', 'rna', 'crct', 'expression']],
  ['hbot',         ['hbot', 'hyperbaric', 'oxygen', 'chamber', 'pressurized']],
  ['training',     ['training', 'hyrox', 'fitness', 'exercise', 'workout', 'strength', 'cardio', 'endurance']],
  ['athleticism',  ['athleticism', 'athletic', 'training', 'fitness', 'performance', 'endurance', 'sport', 'hyrox']],
  ['sleep',        ['sleep', 'circadian', 'rest', 'recovery', 'hrv', 'insomnia']],
  ['supplement',   ['supplement', 'creatine', 'protein', 'vitamin', 'mineral', 'omega', 'magnesium', 'zinc', 'ag1']],
  ['biohacking',   ['biohacking', 'protocol', 'optimization', 'optimisation', 'health', 'longevity', 'hbot']],
  ['sensory',      ['sensory', 'float', 'isolation', 'deprivation', 'tank', 'flotation']],
  ['rna',          ['rna', 'rnaseq', 'transcriptomics', 'gene', 'expression', 'sequencing', 'deseq', 'scanpy', 'seurat']],
  ['machine',      ['machine', 'learning', 'ml', 'model', 'algorithm', 'computational', 'neural']],
  ['vo2',          ['vo2', 'aerobic', 'cardiovascular', 'oxygen', 'capacity', 'fitness']],
  ['cold',         ['cold', 'cryotherapy', 'ice', 'plunge', 'shower']],
]);

function expandWithSynonyms(terms: string[]): string[] {
  const out = new Set(terms);
  for (const t of terms) {
    const syns = SYNONYMS.get(t);
    if (syns) syns.forEach(s => out.add(s));
  }
  return [...out];
}

// ═════════════════════════════════════════════════════════════════════════════
// TEXT PROCESSING
// ═════════════════════════════════════════════════════════════════════════════
const STOPS = new Set([
  'a','about','all','also','an','and','are','as','at','be','been','but','by',
  'can','could','did','do','does','for','from','get','got','has','have','he',
  'her','him','how','i','in','is','it','its','just','let','me','my',
  'no','not','of','on','or','our','s','so','tell','than','that','the','their',
  'them','then','there','these','they','this','those','to','up','us','was',
  'we','what','when','where','which','who','will','with','would','you','your',
  'define','describe','explain','give','list','show',
]);

// Common question-framing words that are NOT topic terms
const FRAME_WORDS = new Set([
  'hugo','think','thinks','thought','say','says','said','know','knows',
  'mention','mentions','talk','talks','discuss','discusses','cover','covers',
  'want','wants','need','needs','make','makes','use','uses','used','using',
  'help','helps','helped','get','gets','give','gives','given',
  'feel','feels','believe','considers','work','works','worked','working',
  'good','bad','best','better','great','sure','true','real','fact',
  'much','many','more','less','most','least','quite','rather','very','really',
]);

function tokenize(text: string): string[] {
  return text
    .toLowerCase()
    .replace(/[^a-z0-9\s]/g, ' ')
    .split(/\s+/)
    .filter(t => t.length > 1 && !STOPS.has(t));
}

function resolvePronounsSimple(text: string): string {
  return text
    .replace(/\bhe\b/gi, 'Hugo')
    .replace(/\bhis\b/gi, 'Hugo')
    .replace(/\bhim\b/gi, 'Hugo');
}

// Key terms = topic-bearing tokens only (strips stop words AND frame words)
function extractKeyTerms(query: string): string[] {
  return tokenize(resolvePronounsSimple(query))
    .filter(t => !FRAME_WORDS.has(t) && t.length > 2)
    .slice(0, 12);
}

// ═════════════════════════════════════════════════════════════════════════════
// EXPLAIN FOLLOW-UP PATTERNS
// Queries like "Why?", "I don't understand", "elaborate" must NOT be tokenised
// literally — they re-search the PREVIOUS substantive topic instead.
// ═════════════════════════════════════════════════════════════════════════════
const EXPLAIN_RE =
  /^(why\??|how so\??|how\??|i\s+don'?t\s+understand\.?|don'?t\s+understand\.?|i\s+don'?t\s+get\s+(it|this)\.?|explain(\s+(more|that|it|further|again))?\??|what\s+do\s+you\s+mean\??|can\s+you\s+clarify\??|elaborate\.?\??|i'?m\s+(confused|lost|unclear)\.?|make\s+it\s+simpler\.?|simplify\.?\??|go\s+on\.?|keep\s+going\.?|tell\s+me\s+more\.?|more\s+detail\.?)\b/i;

// ═════════════════════════════════════════════════════════════════════════════
// QUERY TYPE DETECTION
// ═════════════════════════════════════════════════════════════════════════════
const IDENTITY_RE = /\b(who('s| is) hugo|who is he|about hugo|what is hugo|introduce hugo|hugo chenel)\b/i;
const PURE_FOLLOWUP_RE = /^(more|and\??|what else|anything else|what about (it|that|this|them))\b/i;
const PURE_REF_TOKENS = new Set(['more','else','other','another','further','elaborate','on']);

function detectQueryType(query: string, history: Turn[]): QueryType {
  const userCount = history.filter(t => t.role === 'user').length;
  if (userCount === 0) return 'new_topic';

  const lower = query.toLowerCase().trim();

  if (IDENTITY_RE.test(lower))       return 'identity_about';
  if (EXPLAIN_RE.test(lower))        return 'explain_followup';

  const tokens = tokenize(query);
  if (tokens.length === 0)           return 'direct_followup';
  if (PURE_FOLLOWUP_RE.test(lower))  return 'direct_followup';
  if (tokens.every(t => PURE_REF_TOKENS.has(t))) return 'direct_followup';

  const keyTerms = extractKeyTerms(query);
  if (keyTerms.length === 1 && tokens.length <= 3) return 'ambiguous_followup';
  if (keyTerms.length >= 1)          return 'new_topic';
  return 'ambiguous_followup';
}

// ═════════════════════════════════════════════════════════════════════════════
// QUERY REWRITING
// new_topic: pronouns resolved, NO old context injected — prevents cross-topic bleed.
// follow-ups: expand with previous user turns + source tags.
// explain_followup: use previous substantive query (not the literal "Why?").
// ═════════════════════════════════════════════════════════════════════════════
function rewriteQuery(query: string, type: QueryType, history: Turn[]): string {
  const base = resolvePronounsSimple(query);

  switch (type) {
    case 'identity_about':
      return 'Hugo Chenel who biography profile researcher scientist athlete';

    case 'explain_followup': {
      const prevUser = history
        .filter(t => t.role === 'user')
        .slice()
        .reverse()
        .find(t => !EXPLAIN_RE.test(t.text.toLowerCase().trim()));
      if (!prevUser) return base;
      const prevTags = (history.slice().reverse().find(t => t.role === 'assistant')?.sources ?? [])
        .flatMap(s => s.tags)
        .slice(0, 6)
        .join(' ');
      return [prevUser.text, prevTags].filter(Boolean).join(' ');
    }

    case 'direct_followup': {
      const prevUsers = history.filter(t => t.role === 'user').slice(-2).map(t => t.text);
      const prevTags  = (history.slice().reverse().find(t => t.role === 'assistant')?.sources ?? [])
        .flatMap(s => s.tags)
        .slice(0, 6)
        .join(' ');
      return [prevUsers.join(' '), prevTags, base].filter(Boolean).join(' ');
    }

    case 'ambiguous_followup': {
      const lastUser = history.filter(t => t.role === 'user').slice(-1).map(t => t.text).join(' ');
      return [lastUser, base].filter(Boolean).join(' ');
    }

    case 'new_topic':
    default:
      return base;
  }
}

// ═════════════════════════════════════════════════════════════════════════════
// SEARCH — MiniSearch-powered, runs fresh on every turn
//
// Flow:
//   1. MiniSearch BM25 retrieval (prefix + conservative fuzzy + field boosts)
//   2. Score threshold: drop results below MIN_MS_SCORE
//   3. Hard topic filter: if key terms present, entry body/tags must contain
//      at least one key term (or synonym) — hard zero otherwise
//   4. Return top 5
// ═════════════════════════════════════════════════════════════════════════════
function searchMemory(searchQuery: string, keyTerms: string[]): Entry[] {
  if (!searchQuery.trim()) return [];

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const raw: any[] = ms.search(searchQuery, {
    boost: { title: 10, headingsText: 8, tagsText: 8, category: 5, excerpt: 4, body: 2 },
    // Fuzzy only for terms longer than 4 chars — avoids false matches on short tokens
    fuzzy: (term: string) => term.length > 4 ? 0.15 : false,
    prefix: true,
    combineWith: 'OR',
  });

  dbg('MiniSearch raw:', raw.slice(0, 6).map(r => `${r.id} (${(r.score as number).toFixed(1)})`));

  // Score gate
  let filtered = raw.filter(r => (r.score as number) >= MIN_MS_SCORE);

  // Hard topic filter
  if (keyTerms.length > 0) {
    const expandedKey = expandWithSynonyms(keyTerms);
    filtered = filtered.filter(r => {
      const haystack = (String(r.body ?? '') + ' ' + ((r.tags as string[]) ?? []).join(' ')).toLowerCase();
      const passes = expandedKey.some(t => haystack.includes(t));
      if (!passes) dbg('  HARD-REJECT', r.id, '(no key term/synonym in body+tags)');
      return passes;
    });
  }

  return filtered.slice(0, 5).map(r => ({
    id:       String(r.id ?? ''),
    title:    String(r.title ?? ''),
    url:      String(r.url ?? ''),
    category: String(r.category ?? ''),
    excerpt:  String(r.excerpt ?? ''),
    tags:     (r.tags as string[]) ?? [],
    headings: (r.headings as string[]) ?? [],
    body:     String(r.body ?? ''),
    _score:   r.score as number,
  }));
}

// ═════════════════════════════════════════════════════════════════════════════
// CONFIDENCE CHECK
// Top result must clear MIN_MS_SCORE AND cover at least one key term.
// identity_about queries bypass the score gate (they get a fixed search string).
// ═════════════════════════════════════════════════════════════════════════════
function hasEnoughConfidence(results: Entry[], keyTerms: string[], type: QueryType): boolean {
  if (results.length === 0) return false;

  const top      = results[0];
  const topScore = top._score ?? 0;

  if (type === 'identity_about') return topScore > 0;
  if (topScore < MIN_MS_SCORE)   return false;

  if (keyTerms.length > 0) {
    const haystack = (top.body + ' ' + top.tags.join(' ')).toLowerCase();
    const expanded = expandWithSynonyms(keyTerms);
    const covered  = expanded.filter(t => haystack.includes(t)).length;
    if (covered === 0) return false;
    if (keyTerms.length >= 3 && covered < Math.ceil(keyTerms.length * 0.4)) return false;
  }

  return true;
}

// ═════════════════════════════════════════════════════════════════════════════
// PASSAGE EXTRACTION
// extractSentences: filters any HTML/Markdown artifacts that slipped through.
// extractPassages: ranks sentences by key-term hit count, caps at maxLen chars.
// generateGroundedAnswer: enforces topic isolation (single source when top 2
//   are from different categories), falls back to first clean sentences.
// ═════════════════════════════════════════════════════════════════════════════
function extractSentences(body: string): string[] {
  return body
    .replace(/\s+/g, ' ')
    .split(/(?<=[.!?])\s+/)
    .map(s => s.trim())
    .filter(s => {
      if (s.length < 30)           return false;
      if (s.split(' ').length < 5) return false;
      if (/<[^>]*>/.test(s))       return false; // HTML remnants
      if (/^#{1,6}/.test(s))       return false; // heading markers
      if (/^!\[/.test(s))          return false; // image syntax
      if (/^import\s/i.test(s))    return false;
      if (/^https?:\/\//.test(s))  return false;
      return true;
    });
}

function extractPassages(body: string, passageTerms: string[], maxLen: number): string[] {
  const sentences = extractSentences(body);
  const scored = sentences
    .map(s => {
      const toks = tokenize(s);
      const hits = passageTerms.filter(qt =>
        toks.some(t => t.includes(qt) || qt.includes(t))
      ).length;
      return { s, hits };
    })
    .sort((a, b) => b.hits - a.hits);

  const out: string[] = [];
  let len = 0;
  for (const { s, hits } of scored) {
    if (hits === 0) break;
    if (!out.some(r => r.slice(0, 40) === s.slice(0, 40))) {
      out.push(s);
      len += s.length;
    }
    if (len >= maxLen) break;
  }
  return out;
}

function generateGroundedAnswer(results: Entry[], passageTerms: string[]): string | null {
  // Topic isolation: mixed categories → single source only
  const useSingle = results.length >= 2 && results[0].category !== results[1].category;
  const sourceSet = useSingle ? [results[0]] : results.slice(0, 2);
  dbg('useSingle:', useSingle, '| sources:', sourceSet.map(s => s.id));

  const passages: string[] = [];

  for (const entry of sourceSet) {
    let entryPassages = extractPassages(entry.body, passageTerms, 320);

    // Fallback: entry passed confidence but no sentence scored on key terms
    if (entryPassages.length === 0) {
      dbg('  Fallback passages for', entry.id);
      entryPassages = extractSentences(entry.body).slice(0, 2);
    }

    for (const p of entryPassages) {
      if (p.length >= 30 && !passages.some(e => e.slice(0, 40) === p.slice(0, 40))) {
        passages.push(p);
      }
    }
  }

  if (passages.length === 0) return null;

  let answer = '';
  for (const p of passages.slice(0, 3)) {
    const candidate = answer ? answer + ' ' + p : p;
    if (candidate.length > 520) break;
    answer = candidate;
  }

  if (answer.length > 480) {
    const cut = answer.lastIndexOf('.', 480);
    answer = cut > 100 ? answer.slice(0, cut + 1) : answer.slice(0, 480) + '…';
  }

  return answer.trim() || null;
}

// ═════════════════════════════════════════════════════════════════════════════
// CONVERSATION STATE
// ═════════════════════════════════════════════════════════════════════════════
const history: Turn[] = [];

// ═════════════════════════════════════════════════════════════════════════════
// DOM REFERENCES
// ═════════════════════════════════════════════════════════════════════════════
const thread   = document.getElementById('ah-thread')!;
const msgs     = document.getElementById('ah-msgs')!;
const welcome  = document.getElementById('ah-welcome')!;
const form     = document.getElementById('ah-form')!;
const input    = document.getElementById('ah-input') as HTMLTextAreaElement;
const sendBtn  = document.getElementById('ah-send') as HTMLButtonElement;
const chips    = document.getElementById('ah-chips')!;
const clearBtn = document.getElementById('ah-clear') as HTMLButtonElement;
let firstTurn  = true;

function esc(str: string): string {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function scrollToBottom(): void {
  requestAnimationFrame(() => thread.scrollTo({ top: thread.scrollHeight, behavior: 'smooth' }));
}

function resizeInput(): void {
  input.style.height = 'auto';
  input.style.height = Math.min(input.scrollHeight, 130) + 'px';
}
input.addEventListener('input', resizeInput);

// ═════════════════════════════════════════════════════════════════════════════
// RENDERERS
// ═════════════════════════════════════════════════════════════════════════════
function appendUserMsg(text: string): void {
  if (firstTurn) {
    welcome.style.display = 'none';
    clearBtn.hidden = false;
    firstTurn = false;
  }
  const row = document.createElement('div');
  row.className = 'ah-msg ah-msg--user';
  row.innerHTML = `<div class="ah-bubble ah-bubble--user">${esc(text)}</div>`;
  msgs.appendChild(row);
  scrollToBottom();
}

function appendTyping(): void {
  const row = document.createElement('div');
  row.className = 'ah-msg ah-msg--assistant';
  row.id = 'ah-typing-row';
  row.innerHTML = `
    <div class="ah-avatar" aria-hidden="true">◆</div>
    <div class="ah-msg-col">
      <div class="ah-bubble ah-bubble--assistant">
        <div class="ah-typing-dots"><span></span><span></span><span></span></div>
      </div>
    </div>`;
  msgs.appendChild(row);
  scrollToBottom();
}

function buildSourcesHtml(sources: Entry[], emptyLabel?: string): string {
  if (sources.length > 0) {
    const cards = sources
      .map(
        s => `<a href="${esc(s.url)}" class="ah-src-card">
          <span class="ah-src-cat">${esc(s.category)}</span>
          <span class="ah-src-title">${esc(s.title)}</span>
          <span class="ah-src-arrow">→</span>
        </a>`
      )
      .join('');
    return `<div class="ah-src-area">
      <span class="ah-src-label">Sources</span>
      <div class="ah-src-cards">${cards}</div>
    </div>`;
  }
  return `<div class="ah-src-area ah-src-area--empty">
    <span class="ah-src-label">Sources</span>
    <span class="ah-src-none">${esc(emptyLabel ?? 'No matching content in knowledge base')}</span>
  </div>`;
}

function appendAssistantMsg(text: string, sources: Entry[], type: QueryType): void {
  document.getElementById('ah-typing-row')?.remove();
  const isFollowUp =
    type === 'direct_followup' || type === 'ambiguous_followup' || type === 'explain_followup';
  const badge = isFollowUp ? `<span class="ah-followup-badge">Follow-up</span>` : '';
  const row = document.createElement('div');
  row.className = 'ah-msg ah-msg--assistant';
  row.innerHTML = `
    <div class="ah-avatar" aria-hidden="true">◆</div>
    <div class="ah-msg-col">
      ${badge}
      <div class="ah-bubble ah-bubble--assistant">
        <p class="ah-ans-text">${esc(text)}</p>
      </div>
      ${buildSourcesHtml(sources, 'No matching content in knowledge base')}
    </div>`;
  msgs.appendChild(row);
  scrollToBottom();
}

const TOPIC_SUGGESTIONS = [
  { label: 'Cancer research',   q: 'How do machine learning models help study cancer?' },
  { label: 'Biohacking',        q: 'How does hyperbaric oxygen therapy work?' },
  { label: 'Athletic training', q: 'How does Hugo train for Hyrox?' },
  { label: 'Supplements',       q: 'What supplements support athletic recovery?' },
  { label: 'Athleticism',       q: 'What does Hugo say about athleticism?' },
];

function appendRefusal(text: string, weakSources: Entry[]): void {
  document.getElementById('ah-typing-row')?.remove();
  const suggestHtml = TOPIC_SUGGESTIONS.map(
    s => `<button class="ah-suggest" data-query="${esc(s.q)}">${esc(s.label)} →</button>`
  ).join('');
  const srcLabel =
    weakSources.length > 0
      ? 'Closest matches (may not directly answer)'
      : 'No matching content in knowledge base';
  const row = document.createElement('div');
  row.className = 'ah-msg ah-msg--assistant';
  row.innerHTML = `
    <div class="ah-avatar" aria-hidden="true">◆</div>
    <div class="ah-msg-col">
      <div class="ah-bubble ah-bubble--assistant ah-bubble--warn">
        <p class="ah-ans-text">${esc(text)}</p>
        <div class="ah-suggest-block">
          <span class="ah-suggest-label">Try asking about</span>
          <div class="ah-suggest-row">${suggestHtml}</div>
        </div>
      </div>
      ${buildSourcesHtml(weakSources, srcLabel)}
    </div>`;
  msgs.appendChild(row);
  row.querySelectorAll<HTMLButtonElement>('.ah-suggest').forEach(btn => {
    btn.addEventListener('click', () => runQuery(btn.dataset.query ?? ''));
  });
  scrollToBottom();
}

// ═════════════════════════════════════════════════════════════════════════════
// MAIN QUERY LOOP
// ═════════════════════════════════════════════════════════════════════════════
function runQuery(rawQuery: string): void {
  const q = rawQuery.trim();
  if (!q || sendBtn.disabled) return;

  sendBtn.disabled = true;
  input.value = '';
  resizeInput();

  // 1. Classify query type
  const type = detectQueryType(q, history);
  dbg('Query:', JSON.stringify(q), '| type:', type);

  // 2. Key terms — explain follow-ups derive from the previous substantive query
  //    so "Why?" never drives retrieval with its own (empty) key terms.
  let keyTerms: string[];
  if (type === 'explain_followup') {
    const prevUser = history
      .filter(t => t.role === 'user')
      .slice()
      .reverse()
      .find(t => !EXPLAIN_RE.test(t.text.toLowerCase().trim()));
    keyTerms = prevUser ? extractKeyTerms(prevUser.text) : [];
  } else {
    keyTerms = extractKeyTerms(q);
  }
  dbg('keyTerms:', keyTerms);
  dbg('expanded:', expandWithSynonyms(keyTerms));

  // 3. Passage terms: key terms preferred; fall back to all query tokens
  const passageTerms =
    keyTerms.length > 0 ? keyTerms : tokenize(resolvePronounsSimple(q));

  // 4. Build search query — new_topic never injects prior context
  const searchQuery = rewriteQuery(q, type, history);
  dbg('searchQuery:', JSON.stringify(searchQuery));

  history.push({ role: 'user', text: q, sources: [] });
  appendUserMsg(q);
  appendTyping();

  const delay = 380 + Math.random() * 270;

  setTimeout(() => {
    // 5. Fresh full-index MiniSearch
    const results = searchMemory(searchQuery, keyTerms);
    dbg(
      'After filter:',
      results.map(r => `${r.id} (${r._score?.toFixed(1)})`)
    );

    // 6. Confidence gate
    const confident = hasEnoughConfidence(results, keyTerms, type);
    dbg('confident:', confident, '| topScore:', results[0]?._score?.toFixed(1) ?? '—');

    if (!confident) {
      // Refuse with clean message + topic suggestions
      const topic = keyTerms.slice(0, 2).join(' ');
      const refusalText =
        keyTerms.length > 0
          ? `I couldn't find enough information about "${topic}" in Hugo's public website content to answer that confidently.`
          : "I couldn't find enough relevant content to answer that. Try rephrasing.";
      const weakSources = results.slice(0, 2);
      history.push({ role: 'assistant', text: refusalText, sources: weakSources });
      appendRefusal(refusalText, weakSources);
    } else {
      // Grounded answer from retrieved passages
      const answer =
        generateGroundedAnswer(results, passageTerms) ??
        'Found related content but could not extract a clean passage. Browse the sources below.';
      const topSources = results.slice(0, 3);
      history.push({ role: 'assistant', text: answer, sources: topSources });
      appendAssistantMsg(answer, topSources, type);
    }

    sendBtn.disabled = false;
    input.focus();
  }, delay);
}

// ═════════════════════════════════════════════════════════════════════════════
// CLEAR
// ═════════════════════════════════════════════════════════════════════════════
function clearConversation(): void {
  history.length = 0;
  msgs.innerHTML = '';
  welcome.style.display = '';
  clearBtn.hidden = true;
  firstTurn = true;
  input.focus();
}

// ═════════════════════════════════════════════════════════════════════════════
// EVENT BINDINGS
// ═════════════════════════════════════════════════════════════════════════════
form.addEventListener('submit', e => { e.preventDefault(); runQuery(input.value); });
input.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); runQuery(input.value); }
});
chips.addEventListener('click', e => {
  const chip = (e.target as Element).closest<HTMLElement>('.ah-chip');
  if (chip) runQuery(chip.dataset.query ?? '');
});
clearBtn.addEventListener('click', clearConversation);
document.addEventListener('keydown', e => {
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); input.focus(); }
});
</script>


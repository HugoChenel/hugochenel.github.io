  let activeId: string | null = null;

  function activateNode(id: string) {
    if (activeId === id) { resetAll(); activeId = null; hidePanel(); return; }
    activeId = id;
    const node = NODES[id];
    if (!node) return;
    const connected = new Set([id, ...node.related]);

    document.querySelectorAll<Element>('.sin-node').forEach(el => {
      const elId = (el as HTMLElement).dataset.id!;
      el.classList.remove('sin-node--active','sin-node--connected','sin-node--dimmed');
      el.setAttribute('aria-pressed','false');
      if (elId === id) { el.classList.add('sin-node--active'); el.setAttribute('aria-pressed','true'); }
      else if (connected.has(elId)) { el.classList.add('sin-node--connected'); }
      else { el.classList.add('sin-node--dimmed'); }
    });

    document.querySelectorAll<Element>('.sin-edge').forEach(el => {
      const a = (el as HTMLElement).dataset.a!;
      const b = (el as HTMLElement).dataset.b!;
      el.classList.remove('sin-edge--active','sin-edge--dimmed');
      if (a === id || b === id) { el.classList.add('sin-edge--active'); }
      else { el.classList.add('sin-edge--dimmed'); }
    });

    showDetail(id);
  }

  function resetAll() {
    document.querySelectorAll('.sin-node').forEach(el => {
      el.classList.remove('sin-node--active','sin-node--connected','sin-node--dimmed');
      el.setAttribute('aria-pressed','false');
    });
    document.querySelectorAll('.sin-edge').forEach(el => {
      el.classList.remove('sin-edge--active','sin-edge--dimmed');
    });
  }

  function hidePanel() {
    const panel = document.getElementById('sin-panel');
    if (panel) panel.hidden = true;
  }

  function showDetail(id: string) {
    const node = NODES[id];
    if (!node) return;
    const panel = document.getElementById('sin-panel');
    if (panel) panel.hidden = false;

    const tagEl   = document.getElementById('sin-panel-tag');
    const titleEl = document.getElementById('sin-panel-title');
    const descEl  = document.getElementById('sin-panel-desc');
    const chipsEl = document.getElementById('sin-chips');
    const linkEl  = document.getElementById('sin-panel-link') as HTMLAnchorElement | null;

    if (tagEl)   tagEl.textContent   = node.tag;
    if (titleEl) titleEl.textContent = node.label;
    if (descEl)  descEl.textContent  = node.description;

    if (chipsEl) {
      chipsEl.innerHTML = '';
      node.related.forEach(relId => {
        const rel = NODES[relId];
        if (!rel) return;
        const chip = document.createElement('button');
        chip.className = 'sin-chip';
        chip.setAttribute('type','button');
        chip.textContent = rel.label;
        chip.addEventListener('click', e => { e.stopPropagation(); activateNode(relId); });
        chipsEl.appendChild(chip);
      });
    }

    if (linkEl) {
      if (node.link) {
        linkEl.href = node.link;
        linkEl.textContent = (node.linkLabel ?? 'Explore') + ' →';
        linkEl.hidden = false;
        if (node.link.startsWith('/')) { linkEl.removeAttribute('target'); linkEl.removeAttribute('rel'); }
        else { linkEl.setAttribute('target','_blank'); linkEl.setAttribute('rel','noopener'); }
      } else { linkEl.hidden = true; }
    }
  }

  document.querySelectorAll<Element>('.sin-node').forEach(el => {
    el.addEventListener('click', () => activateNode((el as HTMLElement).dataset.id!));
    el.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') { ke.preventDefault(); activateNode((el as HTMLElement).dataset.id!); }
    });
  });

  document.getElementById('sin-svg')?.addEventListener('click', e => {
    if (!(e.target as Element).closest('.sin-node')) { resetAll(); activeId = null; hidePanel(); }
  });
</script>

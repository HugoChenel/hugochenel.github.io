  { label: "PhD",      value: "Machine learning for genomics · CRCT, Toulouse" },
  { label: "Engineer", value: "Evotec · multi-omics & clinical data modeling" },
  { label: "Based in", value: "Toulouse, France" },
];

const highlightRows = [
  {
    category: "Research",
    items: [
      { value: "PhD",    label: "ML for genomics" },
      { value: "CRCT",   label: "Inserm, Toulouse" },
      { value: "Evotec", label: "Research engineer" },
    ],
  },
  {
    category: "Athletics",
    items: [
      { value: "sub-1h08", label: "Hyrox Open Solo" },
      { value: "Level 8",  label: "CrossFit Open" },
      { value: "62 ml/kg/min", label: "VO2max" },
    ],
  },
  {
    category: "Biohacking",
    items: [
      { value: "0.82",    label: "Pace of aging" },
      { value: "Top 1%",  label: "Biomarkers for age" },
      { value: "Top ranking", label: "Rejuvenation Olympics" },
    ],
  },
];

const links = [
  { label: "Google Scholar",       href: "https://scholar.google.com/citations?user=ENlSzNUAAAAJ&hl=fr&oi=ao" },
  { label: "PhD Thesis — theses.fr", href: "https://theses.fr/s385051" },
  { label: "Strava",               href: "https://www.strava.com/athletes/125862142" },
  { label: "CrossFit Games",       href: "https://games.crossfit.com/athlete/2736016" },
  { label: "Hyrox results",        href: "https://www.hyresult.com/athlete/hugo-chenel?tab=races" },
];

const pages = [
  { label: "Science",      href: "/science",     desc: "Research, publications and academic background" },
  { label: "Biohacking",   href: "/biohacking",  desc: "Health optimisation and longevity protocol" },
  { label: "Athleticism",  href: "/athleticism", desc: "Training, competition results and personal records" },
];
---

<Layout title="About — Hugo Chenel" description="PhD candidate in Machine learning for genomics, hybrid athlete and biohacker based in Toulouse.">

  <!-- Hero -->
  <div class="about-hero-wrap">
    <div class="container">
      <div class="about-hero">
        <div class="about-hero-left">
          <p class="about-eyebrow">About</p>
          <h1 class="about-name">Hugo Chenel</h1>
          <div class="role-tags">
            {roles.map((r) => <span class="role-tag">{r}</span>)}
          </div>
        </div>
        <div class="about-hero-right">
          <div class="aside-card aside-card--highlights">
            <h2 class="aside-heading">Highlights</h2>
            <div class="hl-section">
              <p class="hl-category">Research</p>
              <div class="hl-row">
                <div class="hl-cell"><span class="hl-val">PhD</span><span class="hl-lbl">ML for genomics</span></div>
                <div class="hl-cell"><span class="hl-val">CRCT</span><span class="hl-lbl">Inserm, Toulouse</span></div>
                <div class="hl-cell"><span class="hl-val">Evotec</span><span class="hl-lbl">Research engineer</span></div>
              </div>
            </div>
            <div class="hl-section">
              <p class="hl-category">Biohacking</p>
              <div class="hl-row">
                <div class="hl-cell"><span class="hl-val" data-count-to="0.82" data-count-from="1.00" data-decimals="2">0.82</span><span class="hl-lbl">Pace of aging</span></div>
                <div class="hl-cell"><span class="hl-val">Top ranking</span><span class="hl-lbl">Rejuvenation Olympics</span></div>
                <div class="hl-cell"><span class="hl-val" data-count-to="1" data-count-from="100" data-prefix="Top " data-suffix="%">Top 1%</span><span class="hl-lbl">Biomarkers for age</span></div>
              </div>
            </div>
            <div class="hl-section hl-section--last">
              <p class="hl-category">Athletics</p>
              <div class="hl-row">
                <div class="hl-cell"><span class="hl-val" data-count-to="68" data-count-from="87" data-format="time">sub-1h08</span><span class="hl-lbl">Hyrox Open Solo</span></div>
                <div class="hl-cell"><span class="hl-val" data-count-to="8" data-count-from="1" data-prefix="Level ">Level 8</span><span class="hl-lbl">CrossFit Open</span></div>
                <div class="hl-cell"><span class="hl-val" data-count-to="62" data-count-from="0" data-suffix=" ml/kg/min">62 ml/kg/min</span><span class="hl-lbl">VO2max</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Main two-column layout -->
    <div class="about-grid">

      <!-- Left: bio -->
      <div class="bio-col">
        <p class="bio-text">
          I'm a PhD candidate at the <a href="https://www.crct-inserm.fr/en/" target="_blank" rel="noopener" class="text-link">Cancer Research Center of Toulouse (CRCT)</a> and research engineer at <a href="https://www.evotec.com/" target="_blank" rel="noopener" class="text-link">Evotec</a>, building computational models of tumor progression from multi-omics data.
        </p>
        <p class="bio-text">
          I also train as a hybrid athlete, competing in Hyrox, CrossFit and road races, and experiment extensively with health, performance and longevity.
        </p>
        <p class="bio-text">
          This site is a transparent record of all of it: the research, the training and the self-experimentation.
        </p>

        <!-- Page nav -->
        <div class="page-nav">
          {pages.map((p) => (
            <a href={p.href} class="page-nav-item">
              <span class="page-nav-label">{p.label} →</span>
              <span class="page-nav-desc">{p.desc}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Right: cards -->
      <aside class="aside-col">
        <!-- Currently -->
        <div class="aside-card">
          <h2 class="aside-heading">Currently</h2>
          <dl class="currently-list">
            {currently.map((c) => (
              <div class="currently-item">
                <dt class="curr-label">{c.label}</dt>
                <dd class="curr-value">{c.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </aside>
    </div>

    <!-- Links row -->
    <section class="links-section">
      <h2 class="links-heading">Links</h2>
      <div class="links-row">
        {links.map((link) => (
          <a href={link.href} class="link-card" target="_blank" rel="noopener noreferrer">
            <span class="link-label">{link.label}</span>
            <span class="link-arrow">→</span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <!-- Contact -->
  <div class="contact-wrap">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-left">
          <p class="contact-eyebrow">Contact</p>
          <h2 class="contact-heading">Get in touch</h2>
          <p class="contact-sub">Whether it's about research, training, collaboration or just a question — feel free to reach out.</p>
        </div>
        <form
          class="contact-form"
          action="https://formspree.io/hugo1chenel@gmail.com"
          method="POST"
        >
          <div class="form-row">
            <div class="form-field">
              <label class="form-label" for="contact-name">Name</label>
              <input class="form-input" type="text" id="contact-name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-field">
              <label class="form-label" for="contact-email">Email</label>
              <input class="form-input" type="email" id="contact-email" name="email" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-field">
            <label class="form-label" for="contact-message">Message</label>
            <textarea class="form-textarea" id="contact-message" name="message" placeholder="Your message…" rows="5" required></textarea>
          </div>
          <button class="form-submit" type="submit">
            Send message <span class="submit-arrow">→</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  function animateCounter(el) {
    const from   = parseFloat(el.dataset.countFrom ?? '0');
    const to     = parseFloat(el.dataset.countTo   ?? '0');
    const dec    = parseInt(el.dataset.decimals    ?? '0');
    const prefix = el.dataset.prefix ?? '';
    const suffix = el.dataset.suffix ?? '';
    const fmt    = el.dataset.format;
    const dur    = 6000;
    const t0     = performance.now();
    const easeOut = t => 1 - Math.pow(1 - t, 3);

    function formatTime(min) {
      const h = Math.floor(min / 60);
      const m = Math.floor(min % 60);
      return `sub-${h}h${String(m).padStart(2, '0')}`;
    }

    (function tick(now) {
      const p = Math.min((now - t0) / dur, 1);
      const v = from + (to - from) * easeOut(p);
      el.textContent = fmt === 'time' ? formatTime(v) : prefix + v.toFixed(dec) + suffix;
      if (p < 1) requestAnimationFrame(tick);
    })(t0);
  }

  const card = document.querySelector('.aside-card--highlights');
  if (card) {
    new IntersectionObserver((entries, obs) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        setTimeout(() => {
          e.target.querySelectorAll('[data-count-to]').forEach(animateCounter);
        }, 200);
        obs.unobserve(e.target);
      });
    }, { threshold: 0.4 }).observe(card);
  }
</script>

<style>
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero ── */
  .about-hero-wrap {
    border-bottom: 1px solid var(--border);
    background: radial-gradient(ellipse 50% 90% at 95% 50%, var(--accent-light) 0%, transparent 65%), var(--bg);
  }

  .about-hero {
    padding: 7.5rem 0 6rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 5rem;
  }

  .about-hero-left {
    flex: 1;
    min-width: 0;
  }

  .about-hero-right {
    flex-shrink: 0;
    width: 400px;
    align-self: center;
  }

  .about-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .about-name {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.75rem);
    font-weight: 400;
    line-height: 1.0;
    color: var(--text);
    letter-spacing: -0.015em;
    margin-bottom: 1.75rem;
  }

  .role-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .role-tag {
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border: none;
    padding: 0;
    border-radius: 0;
  }

  .role-tag:not(:last-child)::after {
    content: '·';
    margin: 0 0.65rem;
    color: var(--accent);
    font-weight: 300;
  }

  /* ── Main grid ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 5rem;
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }

  /* ── Bio ── */
  .bio-text {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

.bio-text:last-of-type {
    margin-bottom: 0;
  }

  .text-link {
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s, color 0.2s;
  }

  .text-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .page-nav {
    display: flex;
    flex-direction: column;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .page-nav-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    border-left: 2px solid transparent;
    padding-left: 1rem;
    margin-left: -1rem;
    transition: border-left-color var(--transition), background var(--transition);
  }

  .page-nav-item:hover {
    border-left-color: var(--accent);
    background: var(--accent-light);
  }

  .page-nav-label {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text);
    display: inline-block;
    transition: color var(--transition), transform var(--transition);
  }

  .page-nav-item:hover .page-nav-label {
    color: var(--accent);
    transform: translateX(4px);
  }

  .page-nav-desc {
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ── Aside ── */
  .aside-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .aside-card {
    border: 1px solid var(--border);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .aside-heading {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* Currently */
  .currently-list {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
  }

  .currently-item {
    padding: 0.9rem 0;
    border-top: 1px solid var(--border);
  }

  .currently-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .curr-label {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .curr-value {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.55;
    color: var(--text);
    margin: 0;
  }

  /* Highlights */
  .aside-card--highlights {
    padding-bottom: 0;
  }

  .hl-section {
    margin: 0 -1.75rem 0;
    border-top: 1px solid var(--border);
  }

  .hl-section--last {
    border-bottom: none;
  }

  .hl-category {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0.4rem 1.25rem;
    background: var(--accent-light);
    border-bottom: 1px solid var(--border);
  }

  .hl-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .hl-cell {
    background: var(--bg);
    padding: 1.1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .hl-val {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1;
  }

  .hl-lbl {
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }


  /* ── Links section ── */
  .links-section {
    padding: 4rem 0 6rem;
  }

  .links-heading {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .links-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .link-card {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--border);
    font-size: 0.825rem;
    font-weight: 400;
    color: var(--text-muted);
    transition: border-color var(--transition), color var(--transition);
  }

  .link-card:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .link-arrow {
    font-size: 0.8rem;
    transition: transform var(--transition);
  }

  .link-card:hover .link-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .about-hero {
      flex-direction: column;
      gap: 3rem;
    }

    .about-hero-right {
      width: 100%;
    }
  }

  @media (max-width: 840px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .aside-col {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .aside-card {
      flex: 1 1 280px;
    }
  }

  @media (max-width: 520px) {
    .aside-col {
      flex-direction: column;
    }
  }

  /* ── Contact ── */
  .contact-wrap {
    border-top: 1px solid var(--border);
    background: var(--bg-card);
    padding: 6rem 0 7rem;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .contact-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .contact-sub {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .form-input,
  .form-textarea {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
    resize: none;
    width: 100%;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .form-input:hover,
  .form-textarea:hover {
    border-color: var(--text-muted);
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(42, 92, 69, 0.1);
  }

  html.dark .form-input:focus,
  html.dark .form-textarea:focus {
    box-shadow: 0 0 0 3px rgba(82, 179, 130, 0.12);
  }

  .form-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 0.8rem 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: var(--radius);
    transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
  }

  .form-submit:hover {
    opacity: 0.88;
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .form-submit:active {
    opacity: 1;
    transform: translateY(1px);
    box-shadow: var(--shadow-sm);
  }

  .submit-arrow {
    transition: transform var(--transition);
  }

  .form-submit:hover .submit-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 840px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 520px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

    { label: "Snatch", value: "65 kg" },
    { label: "Military press (strict)", value: "65 kg" },
  ],
  running: [
    { label: "400m", value: "0:58" },
    { label: "800m", value: "2:32" },
    { label: "1600m", value: "5:32" },
    { label: "3200m", value: "11:38" },
    { label: "5K", value: "18:26" },

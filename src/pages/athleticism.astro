<script>
  const btn = document.getElementById('unit-toggle');
  let isMetric = true;
  btn?.addEventListener('click', () => {
    isMetric = !isMetric;
    document.querySelectorAll<HTMLElement>('[data-metric]').forEach(el => {
      el.textContent = isMetric ? el.dataset.metric! : el.dataset.imperial!;
    });
    if (btn) btn.textContent = isMetric ? 'Switch to imperial' : 'Switch to metric';
  });

  // Hyrox progression chart
  const hyroxWrap = document.getElementById('hyroxChartWrap');
  const hyroxTooltip = document.getElementById('hyroxTooltip');
  if (hyroxWrap && hyroxTooltip) {
    const dots = hyroxWrap.querySelectorAll('.pchart-dot');
    dots.forEach((d, i) => { (d as HTMLElement).style.transitionDelay = (0.6 + i * 0.3) + 's'; });

    new IntersectionObserver((entries, obs) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        hyroxWrap.classList.add('animated');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.4 }).observe(hyroxWrap);

    const tipDate = hyroxTooltip.querySelector('.pchart-tip-date');
    const tipVal  = hyroxTooltip.querySelector('.pchart-tip-val');
    const container = hyroxWrap.querySelector('.pace-chart-container') as HTMLElement;
    hyroxWrap.querySelectorAll('.pchart-hit').forEach(hit => {
      const h = hit as SVGCircleElement;
      h.addEventListener('mouseenter', () => {
        tipDate!.textContent = `${h.dataset.race} · ${h.dataset.label}`;
        tipVal!.textContent  = h.dataset.val!;
        const hRect = h.getBoundingClientRect();
        const cRect = container.getBoundingClientRect();
        hyroxTooltip.style.left = (hRect.left + hRect.width / 2 - cRect.left) + 'px';
        hyroxTooltip.style.top  = (hRect.top - cRect.top) + 'px';
        hyroxTooltip.classList.add('visible');
      });
      h.addEventListener('mouseleave', () => hyroxTooltip.classList.remove('visible'));
    });
  }

  // ── Scroll-reveal TOC bar ──────────────────────────────────────
  const tocBarWrap = document.getElementById('toc-bar-wrap');
  const pageTitle  = document.querySelector<HTMLElement>('.page-title');
  if (pageTitle && tocBarWrap) {
    new IntersectionObserver(([e]) => {
      tocBarWrap.classList.toggle('visible', !e.isIntersecting);
    }, { threshold: 0 }).observe(pageTitle);
  }
</script>


<script>
  // ── Scroll-reveal TOC bar ──────────────────────────────────────
  const tocBarWrap = document.getElementById('toc-bar-wrap');
  const sidebarToc = document.querySelector<HTMLElement>('.sc-toc--sidebar');
  if (sidebarToc && tocBarWrap) {
    new IntersectionObserver(([e]) => {
      tocBarWrap.classList.toggle('visible', !e.isIntersecting);
    }, { threshold: 0 }).observe(sidebarToc);
  }

  const wrap = document.getElementById('paceChartWrap');
  const tooltip = document.getElementById('pchartTooltip');

  if (wrap && tooltip) {
    // Stagger dot appearance delays via JS to avoid nth-of-type conflicts
    const dots = wrap.querySelectorAll('.pchart-dot');
    dots.forEach((d, i) => { d.style.transitionDelay = (0.6 + i * 0.5) + 's'; });

    // Trigger line + dot animation on scroll
    new IntersectionObserver((entries, obs) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        wrap.classList.add('animated');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.4 }).observe(wrap);

    // Tooltip: show on hit-area hover
    const tipDate = tooltip.querySelector('.pchart-tip-date');
    const tipVal  = tooltip.querySelector('.pchart-tip-val');

    wrap.querySelectorAll('.pchart-hit').forEach(hit => {
      hit.addEventListener('mouseenter', () => {
        tipDate.textContent = hit.dataset.date;
        tipVal.textContent  = hit.dataset.val;
        tooltip.classList.add('visible');
      });
      hit.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
    });
  }
</script>


---

<Layout
  title="Science — Hugo Chenel"
  description="Computational oncology, multi-omics integration and gene regulatory networks."
>
  <ScrollProgress />

  <!-- ── Page hero ── -->
  <div class="page-hero hero-bg hero-bg--science">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <p class="eyebrow">Science</p>
          <h1 class="page-title">Cancer research<br />&amp; Machine learning</h1>
          <p class="page-lead">PhD research at the intersection of AI/ML, multi-omics data integration and gene regulatory networks, applied to cancer biology.<br><br>
          Currently, I’m working as a research engineer at <a href="https://www.evotec.com/" target="_blank" rel="noopener" class="lead-link">Evotec</a> while pursuing my PhD at the <a href="https://www.crct-inserm.fr/en/" target="_blank" rel="noopener" class="lead-link">Cancer Research Center of Toulouse (CRCT)</a>. My research is supported by Evotec, allowing me to explore innovative approaches in cancer research and drug discovery.</p>
        </div>
        <aside class="hero-right">
          <p class="hero-links-label">Profiles</p>
          <div class="hero-links">
            <a href="https://scholar.google.com/citations?user=ENlSzNUAAAAJ&hl=fr&oi=ao" target="_blank" rel="noopener" class="hero-ext-link">
              <span class="hero-ext-icon" aria-hidden="true">
                <!-- graduation cap -->
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                  <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
              </span>
              <span class="hero-ext-content">
                <span class="hero-ext-label">Google Scholar</span>
                <span class="hero-ext-sub">Publications &amp; citations</span>
              </span>
              <span class="hero-ext-arrow" aria-hidden="true">→</span>
            </a>
            <a href="https://theses.fr/s385051" target="_blank" rel="noopener" class="hero-ext-link">
              <span class="hero-ext-icon" aria-hidden="true">
                <!-- document -->
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
              </span>
              <span class="hero-ext-content">
                <span class="hero-ext-label">PhD Thesis</span>
                <span class="hero-ext-sub">View on theses.fr</span>
              </span>
              <span class="hero-ext-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- ── Table of contents ── -->
  <TableOfContents sections={tocSections} />

  <!-- ── Research focus ── -->
  <section class="focus-section" id="research-focus">
    <div class="container">
      <div class="focus-grid">
        <div class="focus-intro">
          <p class="section-eyebrow">Research focus</p>
          <p class="focus-para">My PhD research is centered on the development of computational models to decode the complexities of tumors, with a strong emphasis on multi-omics data integration and gene regulatory networks. I'm involved in the field of Digital Twins for cancer research, enabling a more personalized and predictive approach to oncology.</p>
        </div>
        <ul class="focus-pillars">
          <li class="focus-pillar">
            <span class="pillar-num">01</span>
            <div>
              <h3 class="pillar-title">Multi-omics integration</h3>
              <p class="pillar-body">Combining transcriptomics, proteomics and clinical data to better explain cancer mechanisms, with a focus on Chronic Lymphocytic Leukaemia.</p>
            </div>
          </li>
          <li class="focus-pillar">
            <span class="pillar-num">02</span>
            <div>
              <h3 class="pillar-title">Gene regulatory networks</h3>
              <p class="pillar-body">Single layer and multilayer network inference, from time-course RNA-seq data to dynamical models of cellular interactions.</p>
            </div>
          </li>
          <li class="focus-pillar">
            <span class="pillar-num">03</span>
            <div>
              <h3 class="pillar-title">Digital Twins for cancer</h3>
              <p class="pillar-body">Building in-silico patient cohorts for virtual clinical trials and drug screening, with a personalized and predictive approach to oncology.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── Publications ── -->
  <section class="section section--light" id="publications">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Publications</h2>
        <a href="https://scholar.google.com/citations?user=ENlSzNUAAAAJ&hl=fr&oi=ao" target="_blank" rel="noopener" class="section-link">Google Scholar &rarr;</a>
      </div>
      <ol class="pub-list" reversed>
        {publications.map((p, i) => (
          <li class="pub-item">
            <div class="pub-index">{publications.length - i}</div>
            <div class="pub-body">
              <div class="pub-top">
                <span class="pub-year">{p.year}</span>
                <span class="pub-badge">{p.label}</span>
              </div>
              <p class="pub-title">{p.title}</p>
              {p.audio && (
                <audio class="pub-audio" controls>
                  <source src={p.audio} type="audio/wav" />
                </audio>
              )}
              <a href={p.href} target="_blank" rel="noopener" class="pub-link">Read {p.label} &rarr;</a>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── Thesis ── -->
  <section class="thesis-section" id="thesis">
    <div class="container">
      <h2 class="section-title">Thesis</h2>
      <div class="thesis-card">
        <aside class="thesis-card-accent">
          <img src="/assets/images/science/universite_toulouse.png" alt="University of Toulouse" class="thesis-logo" />
          <span class="thesis-eyebrow">PhD Thesis · 2026</span>
        </aside>
        <div class="thesis-card-inner">
          <h2 class="thesis-title">Machine learning models of cancer dynamics based on transcriptomics data</h2>
          <div class="thesis-meta-details">
            <div class="thesis-supervisors-row">
              <span class="thesis-meta-label">Supervisors</span>
              <span class="thesis-supervisor-names">Dr. Vera Pancaldi &amp; Dr. Andrei Zinovyev</span>
            </div>
            <div class="thesis-badges">
              <span class="thesis-badge">CIFRE funding</span>
              <span class="thesis-badge">CARe labeling</span>
            </div>
          </div>
          <div class="thesis-actions">
            <a href="https://theses.fr/s385051" target="_blank" rel="noopener" class="thesis-cta">View on theses.fr &rarr;</a>
            <a href="/assets/images/PhD/hugo-chenel-thesis.pdf" target="_blank" rel="noopener" class="thesis-pdf">Download PDF</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tutorials ── -->
  <section class="section section--light" id="tutorials">
    <div class="container">
      <h2 class="section-title">Tutorials</h2>
      <div class="tut-grid">
        <div class="tut-group">
          {tutorials.filter(t => t.category === "Bulk basics").map((t) => (
            <a href={t.href} class="tut-card tut-card--wide">
              <div class="tut-top">
                <span class="tut-category">{t.category}</span>
                <span class="tut-date">{t.date}</span>
              </div>
              <h3 class="tut-name">{t.title}</h3>
              <span class="tut-arrow">&rarr;</span>
            </a>
          ))}
        </div>
        <div class="tut-group tut-group--below">
          {tutorials.filter(t => t.category === "Single cell series").map((t) => (
            <a href={t.href} class="tut-card">
              <div class="tut-top">
                <span class="tut-category">{t.category}</span>
                <span class="tut-date">{t.date}</span>
              </div>
              <h3 class="tut-name">{t.title}</h3>
              <span class="tut-arrow">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Conferences ── -->
  <section class="section" id="conferences">
    <div class="container">
      <h2 class="section-title">Conferences</h2>

      <div class="conf-block">
        <h3 class="conf-type-label">
          <span class="conf-type-dot conf-type-dot--talk"></span>
          Talks
          <span class="conf-count">{conferences.talks.length}</span>
        </h3>
        <div class="conf-list-head">
          <span>Date</span>
          <span>Location</span>
          <span>Event / Presentation</span>
        </div>
        <div class="conf-list">
          {conferences.talks.map((c) => (
            <div class="conf-row">
              <span class="conf-date">{c.date}</span>
              <span class="conf-location">{c.location}</span>
              <div class="conf-body">
                <p class="conf-event">
                  <a href={c.href} target="_blank" rel="noopener" class="conf-link">{c.event}</a>
                  {c.award && <span class="award-badge">🏆 {c.award}</span>}
                </p>
                <p class="conf-title">{c.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="conf-block">
        <h3 class="conf-type-label">
          <span class="conf-type-dot conf-type-dot--poster"></span>
          Posters
          <span class="conf-count">{conferences.posters.length}</span>
        </h3>
        <div class="conf-list-head">
          <span>Date</span>
          <span>Location</span>
          <span>Event / Presentation</span>
        </div>
        <div class="conf-list">
          {conferences.posters.map((c) => (
            <div class="conf-row">
              <span class="conf-date">{c.date}</span>
              <span class="conf-location">{c.location}</span>
              <div class="conf-body">
                <p class="conf-event">
                  <a href={c.href} target="_blank" rel="noopener" class="conf-link">{c.event}</a>
                </p>
                <p class="conf-title">{c.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── Experience ── -->
  <section class="section section--light" id="experience">
    <div class="container">
      <h2 class="section-title">Experience</h2>
      <div class="exp-list">
        {experience.map((e) => (
          <div class:list={["exp-item", `exp-item--${e.type}`]}>
            <div class="exp-left">
              <div class="exp-logo-wrap">
                <img src={e.logo} alt={e.org} class="exp-logo" />
              </div>
              <span class="exp-period">{e.period}</span>
              <span class="exp-location">{e.location}</span>
              <span class:list={["exp-type-badge", `exp-type-badge--${e.type}`]}>
                {e.type === "academia" ? "Academia" : e.type === "industry" ? "Industry" : ""}
              </span>
            </div>
            <div class="exp-right">
              <p class="exp-role">{e.title}</p>
              {e.orgHref
                ? <a href={e.orgHref} target="_blank" rel="noopener" class="exp-org exp-org--link">{e.org}</a>
                : <p class="exp-org">{e.org}</p>
              }
              <p class="exp-desc">{e.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Education ── -->
  <section class="section" id="education">
    <div class="container">
      <h2 class="section-title">Education</h2>
      <div class="edu-list">
        {education.map((e) => (
          <div class="edu-item">
            <div class="edu-year-col">
              <span class="edu-year">{e.year}</span>
            </div>
            <div class="edu-content">
              <p class="edu-degree">{e.degree}</p>
              <div class="edu-institution-row">
                {e.logo && <img src={e.logo} alt={e.institution} class="edu-logo" />}
                <p class="edu-institution">{e.institution}</p>
              </div>
              <ul class="edu-courses">
                {e.courses.map((c) => <li>{c}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Skills & Languages ── -->
  <section class="section section--light" id="skills">
    <div class="container">
      <div class="bottom-stack">

        <div class="skills-col">
          <h2 class="section-title">Technical skills</h2>
          <div class="skills-list">
            {skills.map((s) => (
              <div class="skill-row">
                <span class="skill-cat">{s.category}</span>
                <div class="skill-tags">
                  {s.tools.split(", ").map((tool) => (
                    <span class="skill-tag">{tool}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="lang-col">
          <h2 class="section-title">Languages</h2>
          <div class="lang-list">
            {languages.map((l) => {
              const bars = l.level.includes("Native") ? 5
                : l.level.includes("B2") ? 4
                : l.level.includes("B1") ? 3
                : l.level.includes("A2") ? 2
                : 1;
              return (
                <div class="lang-item">
                  <div class="lang-header">
                    <span class="lang-name">{l.name}</span>
                    <span class="lang-badge">{l.level.split(" · ")[1]}</span>
                  </div>
                  <div class="lang-bars">
                    {[1,2,3,4,5].map((n) => (
                      <span class:list={["lang-bar", { "lang-bar--filled": n <= bars }]}></span>
                    ))}
                  </div>
                  <span class="lang-sublabel">{l.level.split(" · ")[0]}</span>
                  {l.note && (() => {
                    const certName = l.note.split(" — ")[0];
                    const rest = l.note.split(" — ")[1] ?? "";
                    const scoreMatch = rest.match(/^([\d\/]+)\s+(.+)$/);
                    return (
                      <div class="lang-cert">
                        <span class="lang-cert-name">{certName}</span>
                        <div class="lang-cert-right">
                          <span class="lang-cert-score">{scoreMatch ? scoreMatch[1] : rest}</span>
                          {scoreMatch && <span class="lang-cert-divider">|</span>}
                          {scoreMatch && <span class="lang-cert-level">{scoreMatch[2]}</span>}
                        </div>
                      </div>
                    );
                  })()}
                </div>
              );
            })}
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>


<style>

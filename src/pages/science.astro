    color: #fff;
    background: var(--accent);
    padding: 0.8rem 1.75rem;
    border: 1px solid var(--accent);
    transition: opacity 0.2s, transform 0.18s var(--ease);
  }

  .thesis-cta:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .thesis-pdf {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;

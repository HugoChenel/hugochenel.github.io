      width: auto;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 1.1rem 1.5rem;
      gap: 1rem;
      background: var(--accent-light);
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .thesis-logo {
      width: auto;
      height: 36px;
      mix-blend-mode: multiply;
      filter: none;
      opacity: 0.88;
    }

    .thesis-eyebrow {
      text-align: right;
      color: var(--accent);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
    }

    .thesis-title {
      font-size: 1.35rem;
      padding: 1.5rem 1.5rem 1.25rem;
      line-height: 1.32;
    }

    .thesis-meta-details {
      grid-template-columns: 1fr;
    }

    .thesis-supervisors-row {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 1.5rem;
    }

    .thesis-badges {
      padding: 1rem 1.5rem;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .thesis-actions {
      flex-direction: column;
      align-items: stretch;
      padding: 1.25rem 1.5rem;
      gap: 0.6rem;
    }

    .thesis-cta,
    .thesis-pdf {
      display: flex;
      justify-content: center;
      text-align: center;
    }
  }

  /* ── Tutorials ── */
  .tut-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .tut-group {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .tut-group--below {
    margin-top: 0;
  }

  .tut-card--wide {
    grid-column: 1 / -1;
  }

  .tut-card {
    background: var(--bg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background var(--transition), transform var(--transition-slow), box-shadow var(--transition-slow);
  }

  .tut-card:hover {
    background: var(--bg-card);
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

